{
  "vueRoot": "./frontend/src",
  "apiBaseUrl": "/api",
  "aliases": {
    "@": "./frontend/src"
  },
  "nativeBridges": [
    "NativeApp",
    "AndroidBridge",
    "iOSBridge"
  ],
  "services": [
    {
      "id": "user-service",
      "root": "./backend/user-service/src/main/java",
      "type": "spring-boot"
    },
    {
      "id": "product-service",
      "root": "./backend/product-service/src/main/java",
      "type": "spring-boot"
    },
    {
      "id": "order-service",
      "root": "./backend/order-service/src/main/java",
      "type": "spring-boot"
    }
  ],
  "rules": [
    { "id": "no-circular-imports", "type": "deny-circular", "edgeKinds": ["imports"], "severity": "error" },
    { "id": "no-vue-to-spring-service", "type": "deny-direct", "from": ["vue-component"], "to": ["spring-service"], "severity": "error", "message": "Vue components must not directly depend on Spring services" },
    { "id": "hub-limit", "type": "max-dependents", "value": 8, "severity": "warning" }
  ]
}