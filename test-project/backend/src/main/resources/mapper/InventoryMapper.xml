<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.InventoryMapper">
    <select id="findAll" resultType="com.example.model.Inventory">
        SELECT * FROM inventorys
    </select>
    <select id="findById" resultType="com.example.model.Inventory">
        SELECT * FROM inventorys WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="com.example.model.Inventory">
        INSERT INTO inventorys (name, created_at) VALUES (#{name}, NOW())
    </insert>
    <update id="update">
        UPDATE inventorys SET name = #{name} WHERE id = #{id}
    </update>
    <delete id="deleteById">
        DELETE FROM inventorys WHERE id = #{id}
    </delete>
</mapper>
