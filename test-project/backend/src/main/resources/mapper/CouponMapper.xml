<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.CouponMapper">
    <select id="findAll" resultType="com.example.model.Coupon">
        SELECT * FROM coupons
    </select>
    <select id="findById" resultType="com.example.model.Coupon">
        SELECT * FROM coupons WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="com.example.model.Coupon">
        INSERT INTO coupons (name, created_at) VALUES (#{name}, NOW())
    </insert>
    <update id="update">
        UPDATE coupons SET name = #{name} WHERE id = #{id}
    </update>
    <delete id="deleteById">
        DELETE FROM coupons WHERE id = #{id}
    </delete>
</mapper>
