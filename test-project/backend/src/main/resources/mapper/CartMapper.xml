<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.CartMapper">
    <select id="findAll" resultType="com.example.model.Cart">
        SELECT * FROM carts
    </select>
    <select id="findById" resultType="com.example.model.Cart">
        SELECT * FROM carts WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="com.example.model.Cart">
        INSERT INTO carts (name, created_at) VALUES (#{name}, NOW())
    </insert>
    <update id="update">
        UPDATE carts SET name = #{name} WHERE id = #{id}
    </update>
    <delete id="deleteById">
        DELETE FROM carts WHERE id = #{id}
    </delete>
</mapper>
