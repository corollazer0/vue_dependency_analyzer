<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.PaymentMapper">
    <select id="findAll" resultType="com.example.model.Payment">
        SELECT * FROM payments
    </select>
    <select id="findById" resultType="com.example.model.Payment">
        SELECT * FROM payments WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="com.example.model.Payment">
        INSERT INTO payments (name, created_at) VALUES (#{name}, NOW())
    </insert>
    <update id="update">
        UPDATE payments SET name = #{name} WHERE id = #{id}
    </update>
    <delete id="deleteById">
        DELETE FROM payments WHERE id = #{id}
    </delete>
</mapper>