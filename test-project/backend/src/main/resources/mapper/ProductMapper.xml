<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.ProductMapper">
    <select id="findAll" resultType="com.example.model.Product">
        SELECT * FROM products
    </select>
    <select id="findById" resultType="com.example.model.Product">
        SELECT * FROM products WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="com.example.model.Product">
        INSERT INTO products (name, created_at) VALUES (#{name}, NOW())
    </insert>
    <update id="update">
        UPDATE products SET name = #{name} WHERE id = #{id}
    </update>
    <delete id="deleteById">
        DELETE FROM products WHERE id = #{id}
    </delete>
</mapper>
