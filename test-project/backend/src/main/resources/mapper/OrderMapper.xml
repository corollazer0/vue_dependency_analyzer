<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.OrderMapper">
    <select id="findAll" resultType="com.example.model.Order">
        SELECT * FROM orders
    </select>
    <select id="findById" resultType="com.example.model.Order">
        SELECT * FROM orders WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="com.example.model.Order">
        INSERT INTO orders (name, created_at) VALUES (#{name}, NOW())
    </insert>
    <update id="update">
        UPDATE orders SET name = #{name} WHERE id = #{id}
    </update>
    <delete id="deleteById">
        DELETE FROM orders WHERE id = #{id}
    </delete>
</mapper>
