{
  "vueRoot": "./frontend/src",
  "springBootRoot": "./backend/src/main/java",
  "aliases": {
    "@": "./frontend/src"
  },
  "apiBaseUrl": "/api",
  "include": [
    "**/*.vue",
    "**/*.ts",
    "**/*.java",
    "**/*.xml"
  ],
  "exclude": [
    "node_modules/**",
    "dist/**",
    "build/**"
  ],
  "features": [
    { "id": "user", "entry": "frontend/src/components/user/UserList.vue" },
    { "id": "product", "entry": "frontend/src/components/product/ProductList.vue" },
    { "id": "order", "entry": "frontend/src/components/order/OrderList.vue" }
  ]
}