{
  "vueRoot": "./frontend/src",
  "springBootRoot": "./backend/src/main/java",
  "aliases": {
    "@": "./frontend/src"
  },
  "apiBaseUrl": "/api",
  "include": [
    "**/*.vue",
    "**/*.ts",
    "**/*.java",
    "**/*.xml"
  ],
  "exclude": [
    "node_modules/**",
    "dist/**",
    "build/**"
  ]
}