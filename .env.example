# VDA Server Environment Variables
# Copy this file to .env and adjust values as needed.

# ─── Server ───
PORT=3333

# ─── Authentication ───
# Set to "true" to require JWT auth on /api/* endpoints.
# When enabled, VDA_ADMIN_PASSWORD must be set.
VDA_AUTH_ENABLED=false

# JWT signing secret. If not set, a random secret is generated on each startup.
# WARNING: Without a fixed secret, all existing tokens become invalid on server restart.
# In production, always set a stable value.
# VDA_JWT_SECRET=your-secret-here

# Default admin credentials (used when VDA_AUTH_ENABLED=true)
VDA_ADMIN_USER=admin
VDA_ADMIN_PASSWORD=

# ─── Logging ───
# Log level: debug | info | warn | error
VDA_LOG_LEVEL=info

# ─── CORS ───
# Allowed origins. Use "*" for any, or comma-separated list.
VDA_CORS_ORIGIN=*

# ─── Runtime ───
# NODE_ENV=production  # Enables JSON log output (pino default)
