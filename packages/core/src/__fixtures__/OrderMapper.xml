<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.OrderMapper">

    <resultMap id="OrderResultMap" type="com.example.dto.OrderResponse">
        <id property="orderId" column="order_id" javaType="Long"/>
        <result property="customerName" column="customer_name" javaType="String"/>
        <result property="total" column="total_amount" javaType="BigDecimal" jdbcType="DECIMAL"/>
        <result property="createdAt" column="created_at" javaType="LocalDateTime"/>
    </resultMap>

    <select id="findById" resultMap="OrderResultMap">
        SELECT order_id, customer_name, total_amount, created_at
        FROM orders WHERE order_id = #{id}
    </select>

    <select id="findShort" resultType="com.example.dto.OrderSummary">
        SELECT order_id AS orderId, total_amount AS total FROM orders
    </select>

    <insert id="insert" parameterType="com.example.dto.CreateOrderRequest">
        INSERT INTO orders (customer_name, total_amount, created_at)
        VALUES (#{customerName}, #{total}, NOW())
    </insert>

</mapper>
